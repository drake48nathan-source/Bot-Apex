# ═══════════════════════════════════════════════════════════════
# APEX BOT V2 — Template de variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ═══════════════════════════════════════════════════════════════

# ─── Environnement ───────────────────────────────────────────────────────────
ENVIRONMENT=development                        # "development" | "production"
LOG_LEVEL=INFO                                 # "DEBUG" | "INFO" | "WARNING" | "ERROR"
DEMO_MODE=false                                # false = mode réel (clés API requises)
TIMEZONE=Europe/Paris                          # Timezone pour l'affichage des heures

# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./botv2.db              # Phase 1 : SQLite local
# DATABASE_URL=postgresql://user:pass@host:5432/botv2   # Phase 3 : PostgreSQL

# ─── The Odds API ────────────────────────────────────────────────────────────
# Obtenir sur : https://the-odds-api.com (plan Free : 500 req/mois)
ODDS_API_KEY=

# ─── API-Football (RapidAPI) ─────────────────────────────────────────────────
# Obtenir sur : https://rapidapi.com/api-sports/api/api-football (plan Free : 100 req/jour)
API_FOOTBALL_KEY=

# ─── BallDontLie (NBA — Phase 2) ────────────────────────────────────────────
# Obtenir sur : https://www.balldontlie.io
BALLDONTLIE_API_KEY=

# ─── WhatsApp Meta Cloud API ─────────────────────────────────────────────────
# Obtenir sur : https://developers.facebook.com → créer une app → ajouter WhatsApp
# Voir WHATSAPP_SETUP.md pour la procédure complète
WHATSAPP_TOKEN=                                # Token d'accès Meta (temporaire ou permanent)
WHATSAPP_PHONE_NUMBER_ID=                      # ID numérique du numéro WA Business
WHATSAPP_RECIPIENT_NUMBER=+33612345678         # Numéro destinataire principal (format international)

# ─── Telegram (canal principal) ─────────────────────────────────────────────
# Créer un bot avec @BotFather sur Telegram
TELEGRAM_TOKEN=                                # Token du bot (@BotFather → /newbot)
TELEGRAM_CHAT_ID=                             # ID du chat destinataire (envoyer /start au bot d'abord)
ADMIN_TELEGRAM_CHAT_ID=                        # Alertes système (peut être identique à TELEGRAM_CHAT_ID)

# ─── Scheduler — Envoi quotidien ─────────────────────────────────────────────
BOT_SEND_HOUR=9                                # Heure d'envoi du coupon (timezone locale)
BOT_SEND_MINUTE=0                              # Minute d'envoi

# ─── Paramètres métier — Sélection des paris ─────────────────────────────────
EV_THRESHOLD=0.05                              # Seuil EV minimum (+5%)
KELLY_FRACTION=0.25                            # Fraction Kelly (0.25 = quart-Kelly)
MIN_ODDS=1.50                                  # Cote décimale minimum
MAX_ODDS=5.00                                  # Cote décimale maximum
MAX_BETS_PER_DAY=5                             # Nombre max de paris dans le coupon

# ─── Paramètres — Ligues & Sports ────────────────────────────────────────────
FOOTBALL_LEAGUES=soccer_epl,soccer_spain_la_liga,soccer_germany_bundesliga,soccer_italy_serie_a,soccer_france_ligue_one
